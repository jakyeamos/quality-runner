{
  "version": 1,
  "testCommand": "python3.14 scripts/run_pytest_with_lcov.py --changed-only --ignore tests/test_entrypoints.py",
  "coveragePaths": [
    ".pre-cr/coverage.lcov"
  ],
  "coverageFormat": "lcov",
  "qualityAdapters": [
    {
      "name": "environment-contract",
      "command": "python3 scripts/check_environment_contract.py",
      "required": true
    }
  ],
  "threshold": 80,
  "excludePatterns": [
    ".agents/**",
    ".github/**",
    "AGENTS.md",
    ".gitignore",
    ".pre-cr.json",
    ".quality-runner/**",
    ".venv/**",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "docs/**",
    "fixtures/**",
    "LICENSE",
    "packaging/**",
    "README.md",
    "SECURITY.md",
    "pyproject.toml",
    "quality_runner/schemas/**",
    "scripts/**",
    "tests/**"
  ],
  "checks": {
    "coverage": false,
    "security": false,
    "checklist": false
  }
}
