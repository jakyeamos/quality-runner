{
  "version": 1,
  "testCommand": "python3.14 scripts/run_pytest_with_lcov.py",
  "coveragePaths": [
    ".pre-cr/coverage.lcov"
  ],
  "coverageFormat": "lcov",
  "qualityAdapters": [],
  "threshold": 80,
  "excludePatterns": [
    ".gitignore",
    ".pre-cr.json",
    ".quality-runner/**",
    ".venv/**",
    "README.md",
    "pyproject.toml",
    "scripts/**",
    "tests/**"
  ],
  "checks": {
    "coverage": false,
    "security": false,
    "checklist": false
  }
}
