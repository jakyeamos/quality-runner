{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quality-runner.dev/schemas/agent-handoff-v0.2.schema.json",
  "title": "Quality Runner Agent Handoff",
  "type": "object",
  "required": ["schema", "status", "implementation_allowed", "artifact_paths", "warnings", "finding_ids", "slice_ids", "verification_gates"],
  "properties": {
    "schema": { "const": "quality-runner-agent-handoff-v0.2" },
    "run_id": { "type": ["string", "null"] },
    "status": {
      "enum": ["clean", "planned", "gates-discovered", "gates-executed", "gates-blocked", "gates-failed", "gates-clean", "review-required"]
    },
    "implementation_allowed": { "const": false },
    "artifact_paths": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "warnings": { "$ref": "#/$defs/warnings" },
    "finding_ids": { "type": "array", "items": { "type": "string" } },
    "slice_ids": { "type": "array", "items": { "type": "string" } },
    "missing_repo_owned_gates": {
      "type": "array",
      "items": { "$ref": "#/$defs/missingRepoOwnedGate" },
      "default": []
    },
    "runner_provided_checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/runnerProvidedCheck" },
      "default": []
    },
    "adoption_stage": { "$ref": "#/$defs/adoptionStage" },
    "stopping_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "phase_candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/phaseCandidateSummary" },
      "default": []
    },
    "next_phase_candidate": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/phaseCandidateSummary" }
      ]
    },
    "gate_verification": { "$ref": "#/$defs/gateVerificationSummary" },
    "skill_review": { "$ref": "#/$defs/skillReviewSummary" },
    "next_slice": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/remediationSlice" }
      ]
    },
    "verification_gates": { "type": "array", "items": { "type": "string" } },
    "security_review": { "type": "object" },
    "intent": { "$ref": "#/$defs/intentPacket" },
    "intent_docs": {
      "type": "array",
      "items": { "$ref": "#/$defs/intentDoc" }
    },
    "lifecycle_status": {
      "enum": [
        "audit-clean",
        "gates-clean",
        "merge-ready",
        "blocked",
        "failed",
        "workflow-timeout",
        "needs-triage"
      ]
    }
  },
  "$defs": {
    "adoptionStage": {
      "type": "object",
      "required": ["id", "title", "rationale"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 },
        "structural_finding_groups": { "type": "integer", "minimum": 0 },
        "structural_score": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "missingRepoOwnedGate": {
      "type": "object",
      "required": ["id", "severity", "reason", "suggested_command"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "suggested_command": { "type": "string", "minLength": 1 },
        "required_by": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "runnerProvidedCheck": {
      "type": "object",
      "required": ["id", "finding_count", "description"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "finding_count": { "type": "integer", "minimum": 0 },
        "description": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "phaseCandidateSummary": {
      "type": "object",
      "required": [
        "id",
        "domain",
        "title",
        "priority",
        "status",
        "slice_count",
        "finding_count"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "domain": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "priority": { "enum": ["high", "medium", "low"] },
        "status": { "enum": ["planned", "review-required"] },
        "slice_count": { "type": "integer", "minimum": 0 },
        "finding_count": { "type": "integer", "minimum": 0 },
        "score": { "type": "integer", "minimum": 0 },
        "requires_review": { "type": "boolean" },
        "review_slice_count": { "type": "integer", "minimum": 0 },
        "workstreams": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "representative_slice_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "representative_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "actions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "verification_gates": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "remediationSlice": {
      "type": "object",
      "required": ["id", "title", "priority", "findings", "actions", "verification_gates"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "priority": { "enum": ["high", "medium", "low"] },
        "disposition_required": { "type": "boolean" },
        "findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/remediationFinding" },
          "minItems": 1
        },
        "actions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "action_groups": {
          "type": "array",
          "items": { "$ref": "#/$defs/actionGroup" }
        },
        "verification_gates": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "verification_mode": { "enum": ["command", "evidence"] },
        "verification_requirements": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true,
      "allOf": [
        {
          "if": {
            "required": ["verification_mode"],
            "properties": { "verification_mode": { "const": "evidence" } }
          },
          "then": { "required": ["verification_requirements"] }
        }
      ]
    },
    "remediationFinding": {
      "type": "object",
      "required": ["id", "severity", "category", "summary"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["critical", "blocker", "warning", "observation"] },
        "category": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "actionability": { "type": "string", "minLength": 1 },
        "actionability_rationale": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "actionGroup": {
      "type": "object",
      "required": ["class", "actions"],
      "properties": {
        "class": { "type": "string", "minLength": 1 },
        "gate_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "finding_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "actions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      },
      "anyOf": [{ "required": ["gate_ids"] }, { "required": ["finding_ids"] }],
      "additionalProperties": false
    },
    "gateVerificationSummary": {
      "type": "object",
      "required": ["status", "recommended_classification", "blockers"],
      "properties": {
        "status": { "type": "string", "minLength": 1 },
        "recommended_classification": { "type": "string", "minLength": 1 },
        "failure_type": { "type": "string", "minLength": 1 },
        "primary_blocker_class": { "type": "string", "minLength": 1 },
        "blocker_groups": {
          "type": "array",
          "items": { "$ref": "#/$defs/gateBlockerGroup" }
        },
        "blockers": {
          "type": "array",
          "items": { "$ref": "#/$defs/gateBlocker" }
        }
      },
      "additionalProperties": false
    },
    "gateBlockerGroup": {
      "type": "object",
      "required": ["class", "gate_ids"],
      "properties": {
        "class": { "type": "string", "minLength": 1 },
        "gate_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "gateBlocker": {
      "type": "object",
      "required": ["id", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "blocker_class": { "type": "string", "minLength": 1 },
        "failure_type": { "type": "string", "minLength": 1 },
        "skip_type": { "type": "string", "minLength": 1 },
        "blocked_by": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "recommended_action": { "type": "string", "minLength": 1 },
        "dependency_setup": {
          "type": "object",
          "properties": {
            "package_manager": { "type": "string", "minLength": 1 },
            "setup_command": { "type": "string", "minLength": 1 },
            "reason": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "skillReviewSummary": {
      "type": "object",
      "required": ["status", "active_skill_ids", "review_ids", "unresolved_review_ids"],
      "properties": {
        "mode": { "enum": ["off", "auto", "parallel", "required"] },
        "status": { "enum": ["not-run", "review-pending", "review-required", "reviewed", "review-rejected"] },
        "active_skill_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "review_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "unresolved_review_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "automatic": { "type": "boolean" },
        "review_count": { "type": "integer", "minimum": 0 },
        "unresolved_count": { "type": "integer", "minimum": 0 },
        "packet_json": { "type": "string", "minLength": 1 },
        "packet_markdown": { "type": "string", "minLength": 1 },
        "report_json": { "type": "string", "minLength": 1 },
        "report_source_run_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/warning" }
    },
    "warning": {
      "type": "object",
      "required": ["code", "message", "path"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "intentPacket": {
      "type": "object",
      "required": ["schema", "run_id", "goal", "source", "supplied_by", "captured_at"],
      "properties": {
        "schema": { "const": "quality-runner-intent-v0.1" },
        "run_id": { "type": "string", "minLength": 1 },
        "goal": { "type": "string", "minLength": 1 },
        "constraints": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "non_goals": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "tradeoffs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "risk_areas": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "verification_expectations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "source": { "type": "string", "minLength": 1 },
        "supplied_by": { "type": "string", "minLength": 1 },
        "captured_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "intentDoc": {
      "type": "object",
      "required": ["type", "path"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
