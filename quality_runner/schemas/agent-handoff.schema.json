{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quality-runner.dev/schemas/agent-handoff.schema.json",
  "title": "Quality Runner Agent Handoff",
  "type": "object",
  "required": ["schema", "status", "implementation_allowed", "artifact_paths", "warnings", "finding_ids", "slice_ids", "verification_gates"],
  "properties": {
    "schema": { "const": "quality-runner-agent-handoff-v0.1" },
    "run_id": { "type": ["string", "null"] },
    "status": {
      "enum": ["clean", "planned", "gates-discovered", "gates-executed", "gates-blocked", "gates-failed", "gates-clean"]
    },
    "implementation_allowed": { "const": false },
    "artifact_paths": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "warnings": { "$ref": "#/$defs/warnings" },
    "finding_ids": { "type": "array", "items": { "type": "string" } },
    "slice_ids": { "type": "array", "items": { "type": "string" } },
    "missing_repo_owned_gates": {
      "type": "array",
      "items": { "$ref": "#/$defs/missingRepoOwnedGate" },
      "default": []
    },
    "runner_provided_checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/runnerProvidedCheck" },
      "default": []
    },
    "adoption_stage": { "$ref": "#/$defs/adoptionStage" },
    "stopping_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "gate_verification": { "$ref": "#/$defs/gateVerificationSummary" },
    "next_slice": { "type": ["object", "null"] },
    "verification_gates": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "adoptionStage": {
      "type": "object",
      "required": ["id", "title", "rationale"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 },
        "structural_finding_groups": { "type": "integer", "minimum": 0 },
        "structural_score": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "missingRepoOwnedGate": {
      "type": "object",
      "required": ["id", "severity", "reason", "suggested_command"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "suggested_command": { "type": "string", "minLength": 1 },
        "required_by": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "runnerProvidedCheck": {
      "type": "object",
      "required": ["id", "finding_count", "description"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "finding_count": { "type": "integer", "minimum": 0 },
        "description": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "gateVerificationSummary": {
      "type": "object",
      "required": ["status", "recommended_classification", "blockers"],
      "properties": {
        "status": { "type": "string", "minLength": 1 },
        "recommended_classification": { "type": "string", "minLength": 1 },
        "failure_type": { "type": "string", "minLength": 1 },
        "primary_blocker_class": { "type": "string", "minLength": 1 },
        "blocker_groups": {
          "type": "array",
          "items": { "$ref": "#/$defs/gateBlockerGroup" }
        },
        "blockers": {
          "type": "array",
          "items": { "$ref": "#/$defs/gateBlocker" }
        }
      },
      "additionalProperties": false
    },
    "gateBlockerGroup": {
      "type": "object",
      "required": ["class", "gate_ids"],
      "properties": {
        "class": { "type": "string", "minLength": 1 },
        "gate_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "gateBlocker": {
      "type": "object",
      "required": ["id", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "blocker_class": { "type": "string", "minLength": 1 },
        "failure_type": { "type": "string", "minLength": 1 },
        "skip_type": { "type": "string", "minLength": 1 },
        "blocked_by": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "recommended_action": { "type": "string", "minLength": 1 },
        "dependency_setup": {
          "type": "object",
          "properties": {
            "package_manager": { "type": "string", "minLength": 1 },
            "setup_command": { "type": "string", "minLength": 1 },
            "reason": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/warning" }
    },
    "warning": {
      "type": "object",
      "required": ["code", "message", "path"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
