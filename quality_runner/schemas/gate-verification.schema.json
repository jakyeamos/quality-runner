{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quality-runner.dev/schemas/gate-verification.schema.json",
  "title": "Quality Runner Gate Verification",
  "type": "object",
  "required": ["schema", "status", "timeout_seconds", "provenance", "gates"],
  "properties": {
    "schema": { "const": "quality-runner-gate-verification-v0.2" },
    "run_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["passed", "failed", "blocked", "skipped-nonlocal"] },
    "timeout_seconds": { "type": "integer", "minimum": 1 },
    "gate_timeouts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 1 }
    },
    "read_only_gates": { "type": "boolean" },
    "allow_mutating_gates": { "type": "boolean" },
    "failure_type": { "enum": ["workflow-timeout"] },
    "timeout_scope": { "enum": ["verify-phase", "total-refresh"] },
    "phase": { "type": "string", "minLength": 1 },
    "reason": { "type": "string", "minLength": 1 },
    "elapsed_seconds": { "type": "number", "minimum": 0 },
    "environment": {
      "type": "object",
      "additionalProperties": { "type": ["string", "boolean", "null"] }
    },
    "provenance": { "$ref": "#/$defs/provenance" },
    "module_status": { "$ref": "module-status.schema.json" },
    "execution_plan": {
      "type": "array",
      "items": { "$ref": "#/$defs/executionPlanItem" }
    },
    "verification_context": {
      "type": "object",
      "properties": {
        "worktree_mode": { "enum": ["in-place", "disposable"] },
        "base_head": { "type": "string", "minLength": 1 },
        "execution_root": { "type": "string", "minLength": 1 },
        "mutations_isolated": { "type": "boolean" },
        "dirty_source_worktree": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "readiness": { "type": "object" },
    "gates": {
      "type": "array",
      "items": { "$ref": "#/$defs/gate" }
    }
  },
  "$defs": {
    "gate": {
      "type": "object",
      "required": ["id", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["passed", "failed", "blocked", "skipped"] },
        "capability_kind": { "enum": ["local_command", "ci_only", "evidence_file", "evidence", "agent_review", "integrity"] },
        "command": { "type": "string", "minLength": 1 },
        "source": { "type": ["string", "null"] },
        "cwd": { "type": "string", "minLength": 1 },
        "mutating_risk": { "enum": ["safe", "unknown", "mutating"] },
        "exit_code": { "type": ["integer", "null"] },
        "duration_seconds": { "type": "number", "minimum": 0 },
        "timeout_seconds": { "type": "integer", "minimum": 1 },
        "stdout": { "type": "string" },
        "stderr": { "type": "string" },
        "stdout_tail": { "type": "string" },
        "stderr_tail": { "type": "string" },
        "artifact_digest": { "type": ["string", "null"], "pattern": "^(sha256:)?[0-9a-fA-F]{64}$" },
        "reason": { "type": "string", "minLength": 1 },
        "blocker_class": { "type": "string", "minLength": 1 },
        "blocked_by": { "type": "string", "minLength": 1 },
        "failure_type": {
          "enum": [
            "command-failed",
            "timeout",
            "environment-restricted",
            "dependency-setup-blocker",
            "read-only-mutation"
          ]
        },
        "skip_type": { "enum": ["mutating-gate-not-run", "dependency-setup-blocked"] },
        "recommended_action": { "type": "string", "minLength": 1 },
        "diagnostics": { "type": "object" },
        "covered_by": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "executionPlanItem": {
      "type": "object",
      "required": [
        "id",
        "cwd",
        "capability_kind",
        "mutating_risk",
        "local_execution_status",
        "timeout_seconds"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "command": { "type": ["string", "null"] },
        "cwd": { "type": "string", "minLength": 1 },
        "source": { "type": ["string", "null"] },
        "capability_kind": { "enum": ["local_command", "ci_only", "evidence_file", "evidence", "agent_review", "integrity"] },
        "package_manager": { "type": ["string", "null"] },
        "mutating_risk": { "enum": ["safe", "unknown", "mutating"] },
        "local_execution_status": {
          "enum": [
            "will-execute",
            "mutating-skipped",
            "ci-only-skipped",
            "evidence-only-skipped",
            "no-command-skipped"
          ]
        },
        "timeout_seconds": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": ["head_sha", "branch", "ref", "quality_runner_version", "captured_at", "worktree_mode", "workflow_run_id"],
      "properties": {
        "head_sha": { "type": ["string", "null"] },
        "branch": { "type": ["string", "null"] },
        "ref": { "type": ["string", "null"] },
        "quality_runner_version": { "type": "string", "minLength": 1 },
        "captured_at": { "type": "string", "format": "date-time" },
        "worktree_mode": { "enum": ["in-place", "disposable"] },
        "workflow_run_id": { "type": ["string", "null"] },
        "artifact_digest": { "type": ["string", "null"], "pattern": "^(sha256:)?[0-9a-fA-F]{64}$" }
      },
      "additionalProperties": false
    }
  }
}
