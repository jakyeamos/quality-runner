{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quality-runner.dev/schemas/package-manager-preflight.schema.json",
  "title": "Quality Runner Package Manager Preflight",
  "type": "object",
  "required": ["schema", "status", "package_manager", "declared_package_manager", "lockfiles", "warnings"],
  "properties": {
    "schema": { "const": "quality-runner-package-manager-preflight-v0.1" },
    "status": { "enum": ["ok", "warning"] },
    "package_manager": { "type": ["string", "null"] },
    "declared_package_manager": { "type": ["string", "null"] },
    "lockfiles": { "type": "array", "items": { "type": "string" } },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/warning" }
    }
  },
  "$defs": {
    "warning": {
      "type": "object",
      "required": ["code", "message", "path"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
