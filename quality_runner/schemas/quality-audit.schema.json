{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quality-runner.dev/schemas/quality-audit.schema.json",
  "title": "Quality Runner Audit Report",
  "type": "object",
  "required": ["schema", "status", "implementation_allowed", "findings", "warnings"],
  "properties": {
    "schema": { "const": "quality-runner-audit-report-v0.1" },
    "run_id": { "type": ["string", "null"] },
    "repo_root": { "type": ["string", "null"] },
    "profile": { "type": ["string", "null"] },
    "status": { "enum": ["clean", "findings"] },
    "implementation_allowed": { "const": false },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "warnings": { "$ref": "#/$defs/warnings" }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": ["id", "severity", "category", "summary", "evidence", "recommended_fix", "verification"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["critical", "blocker", "warning", "observation"] },
        "owner": { "type": ["string", "null"] },
        "category": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "recommended_fix": { "type": "string", "minLength": 1 },
        "verification": { "type": "array", "items": { "type": "string" } },
        "score": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/warning" }
    },
    "warning": {
      "type": "object",
      "required": ["code", "message", "path"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
