{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quality-runner.dev/schemas/remediation-plan.schema.json",
  "title": "Quality Runner Remediation Plan",
  "type": "object",
  "required": ["schema", "implementation_allowed", "slices", "warnings"],
  "properties": {
    "schema": { "const": "quality-runner-remediation-plan-v0.1" },
    "run_id": { "type": ["string", "null"] },
    "profile": { "type": ["string", "null"] },
    "implementation_allowed": { "const": false },
    "adoption_stage": { "$ref": "#/$defs/adoptionStage" },
    "stopping_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "remediation_context": { "$ref": "#/$defs/remediationContextSummary" },
    "slices": {
      "type": "array",
      "items": { "$ref": "#/$defs/slice" }
    },
    "warnings": { "$ref": "#/$defs/warnings" }
  },
  "$defs": {
    "adoptionStage": {
      "type": "object",
      "required": ["id", "title", "rationale"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 },
        "structural_finding_groups": { "type": "integer", "minimum": 0 },
        "structural_score": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "slice": {
      "type": "object",
      "required": ["id", "title", "priority", "findings", "actions", "verification_gates"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "priority": { "enum": ["high", "medium", "low"] },
        "implementation_allowed": { "const": false },
        "disposition_required": { "type": "boolean" },
        "score": { "type": "integer" },
        "impact": { "type": "string", "minLength": 1 },
        "effort": { "enum": ["S", "M", "L"] },
        "fix_risk": { "enum": ["LOW", "MED", "HIGH"] },
        "confidence": { "enum": ["Low", "Medium", "High", "low", "medium", "high"] },
        "why_now": { "type": "string", "minLength": 1 },
        "leverage": { "type": "object" },
        "planned_at": { "type": "object" },
        "drift_check": { "type": "object" },
        "scope": { "type": "object" },
        "stop_conditions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "source_run_id": { "type": "string", "minLength": 1 },
        "findings": { "type": "array", "items": { "type": "object" } },
        "actions": { "type": "array", "items": { "type": "string" } },
        "action_groups": {
          "type": "array",
          "items": { "$ref": "#/$defs/actionGroup" }
        },
        "verification_gates": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "actionGroup": {
      "type": "object",
      "required": ["class", "actions"],
      "properties": {
        "class": { "type": "string", "minLength": 1 },
        "gate_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "finding_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "actions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      },
      "anyOf": [{ "required": ["gate_ids"] }, { "required": ["finding_ids"] }],
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/warning" }
    },
    "warning": {
      "type": "object",
      "required": ["code", "message", "path"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "remediationContextSummary": {
      "type": "object",
      "required": [
        "schema",
        "status",
        "blocking",
        "record_count",
        "finding_count",
        "ready_count",
        "pending_count"
      ],
      "properties": {
        "schema": { "const": "quality-runner-remediation-context-v0.1" },
        "status": { "enum": ["needs-understanding", "ready"] },
        "blocking": { "type": "boolean" },
        "record_count": { "type": "integer", "minimum": 0 },
        "finding_count": { "type": "integer", "minimum": 0 },
        "ready_count": { "type": "integer", "minimum": 0 },
        "pending_count": { "type": "integer", "minimum": 0 },
        "artifact_path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
