{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quality-runner.dev/schemas/repo-scan.schema.json",
  "title": "Quality Runner Repo Scan",
  "type": "object",
  "required": ["schema", "run_id", "repo_root", "warnings"],
  "properties": {
    "schema": { "const": "quality-runner-repo-scan-v0.1" },
    "run_id": { "type": "string", "minLength": 1 },
    "repo_root": { "type": "string", "minLength": 1 },
    "is_git_repo": { "type": "boolean" },
    "package_manager": { "type": ["string", "null"] },
    "languages": { "type": "array", "items": { "type": "string" } },
    "workspaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/workspace" },
      "default": []
    },
    "scan_exclusions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "ecosystems": { "type": "array", "items": { "type": "string" } },
    "repo_surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/repoSurface" },
      "default": []
    },
    "scripts": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "quality_commands": {
      "type": "array",
      "items": { "$ref": "#/$defs/qualityCommand" },
      "default": []
    },
    "ci_checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/ciCheck" },
      "default": []
    },
    "generated_code": {
      "type": "array",
      "items": { "$ref": "#/$defs/generatedCode" },
      "default": []
    },
    "warnings": { "$ref": "#/$defs/warnings" }
  },
  "$defs": {
    "workspace": {
      "type": "object",
      "required": ["path", "kind", "manifest"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "manifest": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "repoSurface": {
      "type": "object",
      "required": ["id", "kind", "ecosystem", "path", "evidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "ecosystem": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "evidence": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "qualityCommand": {
      "type": "object",
      "required": ["id", "command", "source_type", "source", "language"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "source_type": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 },
        "cwd": { "type": "string", "minLength": 1 },
        "mutating_risk": { "enum": ["safe", "unknown", "mutating"] },
        "local_execution": { "enum": ["ci-only"] }
      },
      "additionalProperties": false
    },
    "ciCheck": {
      "type": "object",
      "required": ["name", "status", "conclusion", "url", "source"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "status": { "type": ["string", "null"] },
        "conclusion": { "type": ["string", "null"] },
        "url": { "type": ["string", "null"] },
        "source": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "generatedCode": {
      "type": "object",
      "required": ["path", "evidence"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "evidence": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/warning" }
    },
    "warning": {
      "type": "object",
      "required": ["code", "message", "path"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
