{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quality-runner.dev/schemas/repo-scan.schema.json",
  "title": "Quality Runner Repo Scan",
  "type": "object",
  "required": ["schema", "run_id", "repo_root", "warnings"],
  "properties": {
    "schema": { "const": "quality-runner-repo-scan-v0.1" },
    "run_id": { "type": "string", "minLength": 1 },
    "repo_root": { "type": "string", "minLength": 1 },
    "is_git_repo": { "type": "boolean" },
    "package_manager": { "type": ["string", "null"] },
    "languages": { "type": "array", "items": { "type": "string" } },
    "scripts": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "quality_commands": {
      "type": "array",
      "items": { "$ref": "#/$defs/qualityCommand" },
      "default": []
    },
    "warnings": { "$ref": "#/$defs/warnings" }
  },
  "$defs": {
    "qualityCommand": {
      "type": "object",
      "required": ["id", "command", "source_type", "source", "language"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "source_type": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/warning" }
    },
    "warning": {
      "type": "object",
      "required": ["code", "message", "path"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
