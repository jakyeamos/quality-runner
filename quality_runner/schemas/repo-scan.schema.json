{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quality-runner.dev/schemas/repo-scan.schema.json",
  "title": "Quality Runner Repo Scan",
  "type": "object",
  "required": ["schema", "run_id", "repo_root", "warnings"],
  "properties": {
    "schema": { "const": "quality-runner-repo-scan-v0.1" },
    "run_id": { "type": "string", "minLength": 1 },
    "repo_root": { "type": "string", "minLength": 1 },
    "git_provenance": { "$ref": "#/$defs/gitProvenance" },
    "provenance": { "$ref": "#/$defs/provenance" },
    "is_git_repo": { "type": "boolean" },
    "package_manager": { "type": ["string", "null"] },
    "languages": { "type": "array", "items": { "type": "string" } },
    "workspaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/workspace" },
      "default": []
    },
    "scan_exclusions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "ecosystems": { "type": "array", "items": { "type": "string" } },
    "repo_surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/repoSurface" },
      "default": []
    },
    "scripts": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "quality_commands": {
      "type": "array",
      "items": { "$ref": "#/$defs/qualityCommand" },
      "default": []
    },
    "ci_checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/ciCheck" },
      "default": []
    },
    "aggregate_coverage": {
      "type": "array",
      "items": { "$ref": "#/$defs/aggregateCoverage" },
      "default": []
    },
    "generated_code": {
      "type": "array",
      "items": { "$ref": "#/$defs/generatedCode" },
      "default": []
    },
    "intent_docs": {
      "type": "array",
      "items": { "$ref": "#/$defs/intentDoc" },
      "default": []
    },
    "module_status": { "$ref": "module-status.schema.json" },
    "warnings": { "$ref": "#/$defs/warnings" }
  },
  "$defs": {
    "workspace": {
      "type": "object",
      "required": ["path", "kind", "manifest"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "manifest": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "repoSurface": {
      "type": "object",
      "required": ["id", "kind", "ecosystem", "path", "evidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "ecosystem": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "evidence": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "qualityCommand": {
      "type": "object",
      "required": ["id", "command", "source_type", "source", "language"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "source_type": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 },
        "cwd": { "type": "string", "minLength": 1 },
        "mutating_risk": { "enum": ["safe", "unknown", "mutating"] },
        "local_execution": { "enum": ["ci-only"] }
      },
      "additionalProperties": false
    },
    "ciCheck": {
      "type": "object",
      "required": ["name", "status", "conclusion", "url", "source"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "status": { "type": ["string", "null"] },
        "conclusion": { "type": ["string", "null"] },
        "url": { "type": ["string", "null"] },
        "source": { "type": "string", "minLength": 1 }
        ,"head_sha": { "type": ["string", "null"] }
        ,"ref": { "type": ["string", "null"] }
        ,"workflow_run_id": { "type": ["string", "null"] }
        ,"captured_at": { "type": ["string", "null"] }
        ,"artifact_digest": { "type": ["string", "null"] }
        ,"source_url": { "type": ["string", "null"] }
        ,"quality_runner_version": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "generatedCode": {
      "type": "object",
      "required": ["path", "evidence"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "evidence": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "gitProvenance": {
      "type": "object",
      "properties": {
        "is_repo": { "type": "boolean" },
        "head_sha": { "type": ["string", "null"] },
        "branch": { "type": ["string", "null"] },
        "dirty": { "type": ["boolean", "null"] },
        "ref": { "type": ["string", "null"] },
        "quality_runner_version": { "type": "string", "minLength": 1 },
        "captured_at": { "type": "string", "format": "date-time" },
        "worktree_mode": { "enum": ["in-place", "disposable"] },
        "workflow_run_id": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": ["head_sha", "branch", "ref", "quality_runner_version", "captured_at", "worktree_mode", "workflow_run_id"],
      "properties": {
        "head_sha": { "type": ["string", "null"] },
        "branch": { "type": ["string", "null"] },
        "ref": { "type": ["string", "null"] },
        "quality_runner_version": { "type": "string", "minLength": 1 },
        "captured_at": { "type": "string", "format": "date-time" },
        "worktree_mode": { "enum": ["in-place", "disposable"] },
        "workflow_run_id": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "aggregateCoverage": {
      "type": "object",
      "required": ["script", "command", "covered_gate_ids", "uncovered_gate_ids", "opaque"],
      "properties": {
        "script": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "covered_gate_ids": { "type": "array", "items": { "type": "string" } },
        "uncovered_gate_ids": { "type": "array", "items": { "type": "string" } },
        "opaque": { "type": "boolean" },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "intentDoc": {
      "type": "object",
      "required": ["type", "path"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/warning" }
    },
    "warning": {
      "type": "object",
      "required": ["code", "message", "path"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
