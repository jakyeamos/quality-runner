{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quality-runner.dev/schemas/run-manifest.schema.json",
  "title": "Quality Runner Run Manifest",
  "type": "object",
  "required": ["schema", "run_id", "mode", "repo_root", "created_at", "quality_runner_version", "implementation_allowed", "git", "artifact_paths"],
  "properties": {
    "schema": { "const": "quality-runner-run-manifest-v0.1" },
    "run_id": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["inspect", "run", "verify-gates", "refresh", "exclusion-preflight"] },
    "repo_root": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "quality_runner_version": { "type": "string", "minLength": 1 },
    "implementation_allowed": { "const": false },
    "git": {
      "type": "object",
      "required": ["is_repo", "head_sha", "branch", "dirty"],
      "properties": {
        "is_repo": { "type": "boolean" },
        "head_sha": { "type": ["string", "null"] },
        "branch": { "type": ["string", "null"] },
        "dirty": { "type": ["boolean", "null"] }
      },
      "additionalProperties": false
    },
    "artifact_paths": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "module_status": { "$ref": "module-status.schema.json" },
    "scan_exclusion_preflight": {
      "type": "object",
      "required": ["scope", "effective_scan_exclusions"],
      "anyOf": [
        { "required": ["stage"] },
        { "required": ["source"] }
      ],
      "properties": {
        "stage": { "enum": ["suggest", "validate", "apply"] },
        "source": { "const": "cli-run-only-overlay" },
        "scope": { "enum": ["all-modules", "module-scoped"] },
        "security_coverage": { "type": "string", "minLength": 1 },
        "packet_json": { "type": ["string", "null"] },
        "report_json": { "type": ["string", "null"] },
        "result_json": { "type": "string", "minLength": 1 },
        "requested_paths": { "type": "array", "items": { "type": "string" } },
        "requested_paths_by_module": { "type": "object", "additionalProperties": { "type": "array", "items": { "type": "string" } } },
        "effective_exclusion_patterns": { "type": "array", "items": { "type": "string" } },
        "effective_exclusion_patterns_by_module": { "type": "object", "additionalProperties": { "type": "array", "items": { "type": "string" } } },
        "config_sha256": { "type": ["string", "null"] },
        "config_mutated": { "const": false },
        "configured_scan_exclusions": { "type": "array", "items": { "type": "string" } },
        "configured_scan_exclusions_by_module": { "type": "object", "additionalProperties": { "type": "array", "items": { "type": "string" } } },
        "packet_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "report_sha256": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" },
        "approved_exclusions": { "type": "array", "items": { "type": "string" } },
        "approved_exclusions_by_module": { "type": "object", "additionalProperties": { "type": "array", "items": { "type": "string" } } },
        "rejected_decisions": { "type": "array", "items": { "type": "object" } },
        "effective_scan_exclusions": { "type": "array", "items": { "type": "string" } },
        "effective_scan_exclusions_by_module": { "type": "object", "additionalProperties": { "type": "array", "items": { "type": "string" } } },
        "config": { "type": "object" }
      },
      "additionalProperties": false
    },
    "quality_skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "version", "content_sha256"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "content_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        },
        "additionalProperties": false
      }
    },
    "intent": {
      "type": "object",
      "required": ["schema", "run_id", "goal", "source", "supplied_by", "captured_at"],
      "properties": {
        "schema": { "const": "quality-runner-intent-v0.1" },
        "run_id": { "type": "string", "minLength": 1 },
        "goal": { "type": "string", "minLength": 1 },
        "constraints": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "non_goals": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "tradeoffs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "risk_areas": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "verification_expectations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "source": { "type": "string", "minLength": 1 },
        "supplied_by": { "type": "string", "minLength": 1 },
        "captured_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  }
}
