{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quality-runner.dev/schemas/run-result.schema.json",
  "title": "Quality Runner Run Result",
  "type": "object",
  "required": ["schema", "status", "implementation_allowed", "run_id", "artifact_paths", "warnings"],
  "properties": {
    "schema": { "const": "quality-runner-run-result-v0.1" },
    "status": { "enum": ["clean", "planned"] },
    "implementation_allowed": { "const": false },
    "run_id": { "type": "string", "minLength": 1 },
    "artifact_paths": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "warnings": { "$ref": "#/$defs/warnings" }
  },
  "$defs": {
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/warning" }
    },
    "warning": {
      "type": "object",
      "required": ["code", "message", "path"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
