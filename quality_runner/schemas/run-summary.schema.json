{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quality-runner.dev/schemas/run-summary.schema.json",
  "title": "Quality Runner Run Summary",
  "type": "object",
  "required": [
    "schema",
    "run_id",
    "status",
    "recommended_classification",
    "gate_results",
    "missing_capabilities",
    "finding_counts",
    "delta"
  ],
  "properties": {
    "schema": { "const": "quality-runner-run-summary-v0.1" },
    "run_id": { "type": "string", "minLength": 1 },
    "path": { "type": "string", "minLength": 1 },
    "status": {
      "enum": [
        "passed",
        "passed-with-findings",
        "failed",
        "blocked",
        "skipped-nonlocal",
        "clean",
        "findings",
        "unknown"
      ]
    },
    "recommended_classification": { "type": "string", "minLength": 1 },
    "gate_results": { "type": "array", "items": { "type": "object" } },
    "missing_capabilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "finding_counts": { "type": "object" },
    "audit_status": { "type": ["string", "null"] },
    "gate_verification_status": { "type": ["string", "null"] },
    "delta": { "type": ["object", "null"] }
  },
  "additionalProperties": false
}
