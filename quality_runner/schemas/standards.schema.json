{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quality-runner.dev/schemas/standards.schema.json",
  "title": "Quality Runner Standards Packet",
  "type": "object",
  "required": ["schema", "profile", "repo_root", "sources", "requirements", "warnings"],
  "properties": {
    "schema": { "const": "quality-runner-standards-packet-v0.1" },
    "profile": { "type": "string", "minLength": 1 },
    "profile_config": { "type": "object" },
    "repo_root": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source" }
    },
    "config": { "type": "object" },
    "requirements": {
      "type": "array",
      "items": { "$ref": "#/$defs/requirement" }
    },
    "warnings": { "$ref": "#/$defs/warnings" }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": ["type", "path"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "requirement": {
      "type": "object",
      "required": ["id", "level", "description"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "level": { "enum": ["hard", "warning"] },
        "description": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/warning" }
    },
    "warning": {
      "type": "object",
      "required": ["code", "message", "path"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
